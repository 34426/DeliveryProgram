<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.CaipinpeisongDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.CaipinpeisongEntity" id="caipinpeisongMap">
        <result property="orderid" column="orderid"/>
        <result property="buynumber" column="buynumber"/>
        <result property="shangjiamingcheng" column="shangjiamingcheng"/>
        <result property="shangjiadizhi" column="shangjiadizhi"/>
        <result property="address" column="address"/>
        <result property="zhanghao" column="zhanghao"/>
        <result property="lianxifangshi" column="lianxifangshi"/>
        <result property="dingdanxiangqing" column="dingdanxiangqing"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.CaipinpeisongView" >

		SELECT  caipinpeisong.* FROM caipinpeisong  caipinpeisong 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.CaipinpeisongView" >
		SELECT * FROM caipinpeisong  caipinpeisong <where> 1=1 ${ew.sqlSegment}</where>
	</select>



</mapper>
